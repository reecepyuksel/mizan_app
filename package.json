{
  "name": "mizan-app",
  "version": "1.0.0",
  "description": "Mizan - Modern Islami Yasam Rehberi backend (NestJS + PostgreSQL + Sequelize)",
  "main": "dist/main.js",
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "start": "node dist/main.js",
    "start:dev": "ts-node-dev --respawn --transpile-only src/main.ts",
    "db:up": "docker compose up -d db",
    "redis:up": "docker compose up -d redis",
    "infra:up": "docker compose up -d db redis",
    "db:down": "docker compose down",
    "db:logs": "docker compose logs -f db",
    "redis:logs": "docker compose logs -f redis",
    "db:bulk-import": "ts-node src/scripts/bulk-import.ts",
    "perf:db": "ts-node src/scripts/db-performance-report.ts",
    "perf:load:search": "node scripts/load-test.js search",
    "perf:load:prayer": "node scripts/load-test.js prayer",
    "perf:load:sync": "node scripts/load-test.js sync",
    "perf:load:notifications": "node scripts/load-test.js notifications",
    "perf:load:all": "node scripts/load-test.js all"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "dependencies": {
    "@nestjs/common": "^11.1.18",
    "@nestjs/config": "^4.0.3",
    "@nestjs/core": "^11.1.18",
    "@nestjs/platform-express": "^11.1.18",
    "@nestjs/swagger": "^11.2.6",
    "adhan": "^4.4.3",
    "bullmq": "^5.73.2",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.15.1",
    "firebase-admin": "^13.7.0",
    "ioredis": "^5.10.1",
    "pg": "^8.20.0",
    "pg-hstore": "^2.3.4",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.2",
    "sequelize": "^6.37.8",
    "sequelize-typescript": "^2.1.6",
    "swagger-ui-express": "^5.0.1",
    "tz-lookup": "^6.1.25",
    "uuid": "^13.0.0"
  },
  "devDependencies": {
    "@types/node": "^25.5.2",
    "@types/tz-lookup": "^6.1.2",
    "autocannon": "^8.0.0",
    "ts-node": "^10.9.2",
    "ts-node-dev": "^2.0.0",
    "typescript": "^6.0.2"
  }
}
